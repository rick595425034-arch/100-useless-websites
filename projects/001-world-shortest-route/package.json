{
  "name": "world-shortest-route",
  "version": "0.1.0",
  "private": true,
  "main": "desktop-app/main.cjs",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "desktop:build": "vite build --config desktop/vite.config.ts",
    "desktop:play": "npm run desktop:build && electron .",
    "desktop:dist": "npm run desktop:build && electron-builder --mac dmg"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "build": {
    "appId": "com.aether.path",
    "productName": "AETHER PATH",
    "electronDist": "node_modules/electron/dist",
    "artifactName": "AETHER-PATH-${version}-${arch}.${ext}",
    "directories": {
      "app": "desktop-app",
      "output": "release"
    },
    "files": [
      "main.cjs",
      "site/**/*"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.travel",
      "identity": null,
      "icon": "AETHER.icns"
    },
    "dmg": {
      "title": "AETHER PATH",
      "iconSize": 100,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 190
        },
        {
          "x": 390,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
